{
  "panels": [
    {
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "description": "Live pod count per service. Matches Helm values-kind.yaml replicaCount. Green = at least one replica UP.",
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "red",
                "value": null
              },
              {
                "color": "green",
                "value": 1
              }
            ]
          },
          "unit": "short"
        }
      },
      "gridPos": {
        "h": 5,
        "w": 12,
        "x": 0,
        "y": 0
      },
      "id": 7,
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "textMode": "value_and_name"
      },
      "targets": [
        {
          "expr": "count by (app) (up{job=\"kubernetes-pods\", app=~\"(ingest|query)-api|stream-processor|clickhouse-sink\"})",
          "legendFormat": "{{app}}"
        }
      ],
      "title": "Replicas per service (scrape targets UP)",
      "type": "stat"
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "description": "1 = Prometheus successfully scraped this pod's /metrics on the last poll. 0 = DOWN.",
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "red",
                "value": null
              },
              {
                "color": "green",
                "value": 1
              }
            ]
          }
        }
      },
      "gridPos": {
        "h": 5,
        "w": 12,
        "x": 12,
        "y": 0
      },
      "id": 6,
      "options": {
        "colorMode": "background"
      },
      "targets": [
        {
          "expr": "up{job=\"kubernetes-pods\", app=~\"(ingest|query)-api|stream-processor|clickhouse-sink\"}",
          "legendFormat": "{{app}} — {{instance}}"
        }
      ],
      "title": "Scrape up per pod",
      "type": "stat"
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 5
      },
      "id": 1,
      "targets": [
        {
          "expr": "go_goroutines{job=\"kubernetes-pods\"}",
          "legendFormat": "{{app}} — {{instance}}"
        }
      ],
      "title": "Goroutines per pod",
      "type": "timeseries"
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "decmbytes"
        }
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 5
      },
      "id": 2,
      "targets": [
        {
          "expr": "go_memstats_heap_inuse_bytes{job=\"kubernetes-pods\"} / 1024 / 1024",
          "legendFormat": "{{app}} — {{instance}}"
        }
      ],
      "title": "Heap in-use (MB) per pod",
      "type": "timeseries"
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 13
      },
      "id": 3,
      "targets": [
        {
          "expr": "rate(process_cpu_seconds_total{job=\"kubernetes-pods\"}[5m])",
          "legendFormat": "{{app}} — {{instance}}"
        }
      ],
      "title": "Process CPU rate (cores) per pod",
      "type": "timeseries"
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "MBs"
        }
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 13
      },
      "id": 4,
      "targets": [
        {
          "expr": "rate(go_memstats_alloc_bytes_total{job=\"kubernetes-pods\"}[5m]) / 1024 / 1024",
          "legendFormat": "{{app}} — {{instance}}"
        }
      ],
      "title": "Allocation rate (MB/s) — proxy for work",
      "type": "timeseries"
    }
  ],
  "refresh": "10s",
  "schemaVersion": 39,
  "tags": [
    "dream"
  ],
  "time": {
    "from": "now-30m",
    "to": "now"
  },
  "timezone": "browser",
  "title": "Dream Flight — Runtime",
  "uid": "dream-runtime",
  "datasource": null
}
