{
  "title": "Live Flights",
  "uid": "live-flights",
  "schemaVersion": 39,
  "version": 1,
  "timezone": "utc",
  "refresh": "30s",
  "time": { "from": "now-1h", "to": "now" },
  "tags": ["dream-flight", "aviation"],
  "panels": [
    {
      "id": 1,
      "title": "Active aircraft (last 5m)",
      "type": "stat",
      "datasource": { "type": "postgres", "uid": "postgres" },
      "gridPos": { "x": 0, "y": 0, "w": 6, "h": 5 },
      "options": {
        "reduceOptions": { "values": false, "calcs": ["lastNotNull"] },
        "colorMode": "value",
        "textMode": "auto"
      },
      "targets": [
        {
          "refId": "A",
          "format": "table",
          "rawSql": "SELECT count(*) AS active FROM aircraft_state WHERE observed_at >= now() - interval '5 minutes'"
        }
      ]
    },
    {
      "id": 2,
      "title": "Airborne",
      "type": "stat",
      "datasource": { "type": "postgres", "uid": "postgres" },
      "gridPos": { "x": 6, "y": 0, "w": 6, "h": 5 },
      "options": {
        "reduceOptions": { "values": false, "calcs": ["lastNotNull"] },
        "colorMode": "value",
        "textMode": "auto"
      },
      "targets": [
        {
          "refId": "A",
          "format": "table",
          "rawSql": "SELECT count(*) FILTER (WHERE NOT on_ground) AS airborne FROM aircraft_state WHERE observed_at >= now() - interval '5 minutes'"
        }
      ]
    },
    {
      "id": 3,
      "title": "On ground",
      "type": "stat",
      "datasource": { "type": "postgres", "uid": "postgres" },
      "gridPos": { "x": 12, "y": 0, "w": 6, "h": 5 },
      "options": {
        "reduceOptions": { "values": false, "calcs": ["lastNotNull"] },
        "colorMode": "value",
        "textMode": "auto"
      },
      "targets": [
        {
          "refId": "A",
          "format": "table",
          "rawSql": "SELECT count(*) FILTER (WHERE on_ground) AS on_ground FROM aircraft_state WHERE observed_at >= now() - interval '5 minutes'"
        }
      ]
    },
    {
      "id": 4,
      "title": "Avg cruise altitude (m)",
      "type": "stat",
      "datasource": { "type": "postgres", "uid": "postgres" },
      "gridPos": { "x": 18, "y": 0, "w": 6, "h": 5 },
      "options": {
        "reduceOptions": { "values": false, "calcs": ["lastNotNull"] },
        "colorMode": "value",
        "textMode": "auto"
      },
      "targets": [
        {
          "refId": "A",
          "format": "table",
          "rawSql": "SELECT round(avg(baro_altitude_m)::numeric, 0) AS avg_alt FROM aircraft_state WHERE NOT on_ground AND baro_altitude_m IS NOT NULL AND observed_at >= now() - interval '5 minutes'"
        }
      ]
    },
    {
      "id": 5,
      "title": "Top 10 origin countries (active last 5m)",
      "type": "barchart",
      "datasource": { "type": "postgres", "uid": "postgres" },
      "gridPos": { "x": 0, "y": 5, "w": 12, "h": 9 },
      "options": {
        "orientation": "horizontal",
        "xField": "aircraft",
        "showValue": "always"
      },
      "fieldConfig": { "defaults": { "custom": {} }, "overrides": [] },
      "targets": [
        {
          "refId": "A",
          "format": "table",
          "rawSql": "SELECT origin_country, count(*) AS aircraft FROM aircraft_state WHERE observed_at >= now() - interval '5 minutes' GROUP BY origin_country ORDER BY aircraft DESC LIMIT 10"
        }
      ]
    },
    {
      "id": 6,
      "title": "Aircraft observed (last 1h, by minute)",
      "type": "timeseries",
      "datasource": { "type": "postgres", "uid": "postgres" },
      "gridPos": { "x": 12, "y": 5, "w": 12, "h": 9 },
      "fieldConfig": { "defaults": { "custom": { "drawStyle": "line", "lineWidth": 2 } }, "overrides": [] },
      "targets": [
        {
          "refId": "A",
          "format": "time_series",
          "rawSql": "SELECT date_trunc('minute', observed_at) AS time, count(DISTINCT icao24) AS aircraft FROM flight_telemetry WHERE observed_at >= now() - interval '1 hour' GROUP BY 1 ORDER BY 1"
        }
      ]
    },
    {
      "id": 7,
      "title": "Recent emergency squawks (7500/7600/7700)",
      "type": "table",
      "datasource": { "type": "postgres", "uid": "postgres" },
      "gridPos": { "x": 0, "y": 14, "w": 24, "h": 8 },
      "options": { "showHeader": true },
      "fieldConfig": { "defaults": { "custom": {} }, "overrides": [] },
      "targets": [
        {
          "refId": "A",
          "format": "table",
          "rawSql": "SELECT observed_at, icao24, callsign, origin_country, squawk, lat, lon, baro_altitude_m FROM flight_telemetry WHERE squawk IN ('7500','7600','7700') AND observed_at >= now() - interval '6 hours' ORDER BY observed_at DESC LIMIT 50"
        }
      ]
    }
  ]
}
